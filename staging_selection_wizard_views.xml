<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ktx_settlement_staging_list" model="ir.ui.view">
        <field name="name">ktx.settlement.staging.list</field>
        <field name="model">ktx.settlement.staging</field>
        <field name="arch" type="xml">
            <list string="Gastos por Liquidar"
                decoration-warning="state == 'pending'"
                decoration-danger="state == 'in_settlement'"
                decoration-success="state == 'done'">
                <field name="move_id" string="Factura / Asiento"/>
                <field name="move_type" string="Tipo"/>
                <field name="ref" string="Referencia / Serie"/>
                <field name="partner_id" string="Proveedor"/>
                <field name="invoice_date" string="Fecha"/>
                <field name="currency_id" string="Moneda" groups="base.group_multi_currency"/>
                <field name="amount_total" string="Total" sum="Total General"/>
                <field name="move_state" string="Estado Factura"/>
                <field name="state_color" column_invisible="1"/>
                <field name="state" string="Estado" widget="badge" options="{'color_field': 'state_color'}"/>
                <field name="company_id" string="Compañía" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_ktx_settlement_staging_form" model="ir.ui.view">
        <field name="name">ktx.settlement.staging.form</field>
        <field name="model">ktx.settlement.staging</field>
        <field name="arch" type="xml">
            <form string="Gasto por Liquidar">
                <sheet>
                    <!-- New-record prompt: no move_id yet -->
                    <div class="o_field_widget o_form_label text-center py-5" invisible="move_id">
                        <h4 class="text-muted mb-4">¿Qué deseas hacer?</h4>
                        <button name="action_create_vendor_receipt"
                            type="object"
                            string="Crear Nuevo Recibo de Proveedor"
                            class="btn btn-primary btn-lg"/>
                        <p class="text-muted mt-3 small">
                            O cierra esta ventana y usa la acción
                            <strong>"Agregar a Liquidación"</strong>
                            desde una factura de proveedor ya existente.
                        </p>
                    </div>

                    <!-- Existing record info -->
                    <div invisible="not move_id">
                        <div class="oe_button_box" name="button_box">
                            <button name="action_create_vendor_receipt"
                                type="object"
                                string="Nuevo Recibo"
                                icon="fa-plus-circle"
                                class="oe_stat_button"/>
                        </div>
                        <group>
                            <group string="Información del Documento">
                                <field name="move_id" readonly="1"/>
                                <field name="move_type" readonly="1"/>
                                <field name="ref" readonly="1"/>
                                <field name="partner_id" readonly="1"/>
                                <field name="invoice_date" readonly="1"/>
                                <field name="move_state" readonly="1"/>
                            </group>
                            <group string="Importes">
                                <field name="currency_id" readonly="1" groups="base.group_multi_currency"/>
                                <field name="amount_total" readonly="1"/>
                                <field name="state_color" invisible="1"/>
                                <field name="state" readonly="1" widget="badge" options="{'color_field': 'state_color'}"/>
                            </group>
                        </group>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ktx_settlement_staging_search" model="ir.ui.view">
        <field name="name">ktx.settlement.staging.search</field>
        <field name="model">ktx.settlement.staging</field>
        <field name="arch" type="xml">
            <search string="Buscar Gastos por Liquidar">
                <field name="move_id" string="Factura / Asiento"/>
                <field name="ref" string="Referencia / Serie"/>
                <field name="partner_id" string="Proveedor"/>
                <filter name="filter_pending" string="Pendientes" domain="[('state', '=', 'pending')]"/>
                <filter name="filter_in_settlement" string="En Liquidación" domain="[('state', '=', 'in_settlement')]"/>
                <filter name="filter_done" string="Liquidados" domain="[('state', '=', 'done')]"/>
                <filter name="filter_invoices" string="Solo Facturas" domain="[('move_type', '=', 'in_invoice')]"/>
                <filter name="filter_entries" string="Solo Asientos" domain="[('move_type', '=', 'entry')]"/>
            </search>
        </field>
    </record>

    <record id="action_ktx_settlement_staging" model="ir.actions.act_window">
        <field name="name">Gastos por Liquidar</field>
        <field name="res_model">ktx.settlement.staging</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '!=', 'done'), ('move_id', '!=', False)]</field>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay gastos pendientes de liquidar.
            </p>
            <p>
                Para agregar documentos, ve a una factura de proveedor publicada
                y usa la acción "Agregar a Liquidación de Gastos".
            </p>
        </field>
    </record>

    <!-- Acción de servidor: crear liquidación desde gastos seleccionados -->
    <record id="action_server_create_settlement_from_staging" model="ir.actions.server">
        <field name="name">Crear Liquidación</field>
        <field name="model_id" ref="model_ktx_settlement_staging"/>
        <field name="binding_model_id" ref="model_ktx_settlement_staging"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_create_settlement()
</field>
    </record>


</odoo>
