<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ktx_config_settings_form" model="ir.ui.view">
        <field name="name">ktx.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority">9999</field>
        <field name="arch" type="xml">
            <form string="Configuración — Liquidaciones" class="o_base_settings">
                <div class="o_setting_container">
                    <div class="settings o_searchable_setting">
                        <div class="app_settings_block">
                            <h2>General</h2>
                            <div class="row mt16 o_settings_container">
                                <div class="col-12 col-lg-6 o_setting_box">
                                    <div class="o_setting_left_pane">
                                        <field name="ktx_allow_journal_entries"/>
                                    </div>
                                    <div class="o_setting_right_pane">
                                        <label for="ktx_allow_journal_entries"
                                            string="Incluir Asientos Contables en Liquidaciones"/>
                                        <div class="text-muted">
                                            Permite agregar asientos contables genéricos a Gastos
                                            por Liquidar (no solo facturas de proveedor).
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6 o_setting_box">
                                    <div class="o_setting_left_pane">
                                        <field name="ktx_multi_company_staging"/>
                                    </div>
                                    <div class="o_setting_right_pane">
                                        <label for="ktx_multi_company_staging"
                                            string="Asignación Multiempresa"/>
                                        <div class="text-muted">
                                            Muestra gastos de todas las empresas en la lista de
                                            Gastos por Liquidar y en el selector de gastos para
                                            una liquidación.
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 o_setting_box"
                                    invisible="not ktx_multi_company_staging">
                                    <div class="alert alert-info" role="alert" style="margin-top: 8px;">
                                        <strong>⚠️ Para que la Asignación Multiempresa funcione correctamente:</strong>
                                        <ul class="mb-0">
                                            <li>Active las empresas involucradas en su perfil de usuario
                                                (ícono de empresa en la barra superior de Odoo).</li>
                                            <li>En cada liquidación multiempresa, configure la Cuenta por Cobrar
                                                Intercompañía y agregue la cuenta por pagar de cada empresa
                                                en la pestaña «Intercompañía» de la liquidación.</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="o_setting_footer">
                    <button string="Guardar" name="execute" type="object" class="btn-primary"/>
                    <button string="Descartar" name="cancel" type="object" class="btn-secondary"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_ktx_expense_config_settings" model="ir.actions.act_window">
        <field name="name">Configuración</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ktx_config_settings_form"/>
        <field name="target">current</field>
        <field name="context">{'module': 'ktx_expense_management'}</field>
    </record>

</odoo>
