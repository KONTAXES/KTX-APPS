<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ktx_settlement_payment_wizard_form" model="ir.ui.view">
        <field name="name">ktx.settlement.payment.wizard.form</field>
        <field name="model">ktx.settlement.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Pago de Liquidación">
                <sheet>
                    <group string="Información del Pago">
                        <group>
                            <field name="settlement_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="journal_currency_id" invisible="1"/>
                            <field name="journal_id" required="1"/>
                            <field name="payment_method_line_id"
                                domain="[('journal_id', '=', journal_id)]"/>
                            <field name="payment_date" required="1"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="communication" placeholder="Memo / Concepto"/>
                            <field name="payment_reference" placeholder="Núm. cheque, transferencia, etc."/>
                        </group>
                    </group>

                    <group string="Diferencia" invisible="payment_difference == 0">
                        <group>
                            <field name="payment_difference" readonly="1"/>
                            <field name="payment_difference_handling" widget="radio"/>
                        </group>
                        <group invisible="payment_difference_handling != 'reconcile'">
                            <field name="writeoff_account_id"
                                required="payment_difference_handling == 'reconcile' and payment_difference != 0"/>
                            <field name="writeoff_label"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_pay"
                        string="Registrar Pago"
                        type="object"
                        class="btn-primary"/>
                    <button string="Cancelar"
                        class="btn-secondary"
                        special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
