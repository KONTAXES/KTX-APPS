<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ktx_staging_selection_wizard_form" model="ir.ui.view">
        <field name="name">ktx.staging.selection.wizard.form</field>
        <field name="model">ktx.staging.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Agregar Gastos a Liquidación">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_select_all"
                                string="Seleccionar Todo"
                                type="object"
                                icon="fa-check-square-o"
                                class="oe_stat_button"/>
                    </div>
                    <group>
                        <field name="settlement_id" readonly="1"/>
                    </group>
                    <field name="line_ids" nolabel="1">
                        <list string="Gastos Disponibles"
                              create="0" delete="0"
                              editable="top"
                              decoration-success="selected == True">
                            <field name="selected" string="✓"/>
                            <field name="staging_id" column_invisible="1"/>
                            <field name="move_name" string="Póliza" readonly="1"/>
                            <field name="ref" string="Referencia" readonly="1"/>
                            <field name="partner_id" string="Proveedor" readonly="1"/>
                            <field name="invoice_date" string="Fecha" readonly="1"/>
                            <field name="currency_id" readonly="1"
                                   groups="base.group_multi_currency"/>
                            <field name="amount_total" string="Total"
                                   readonly="1" sum="Total"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_add_lines"
                            string="Agregar Seleccionados"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
