<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ktx_expense_dashboard_form" model="ir.ui.view">
        <field name="name">ktx.expense.dashboard.form</field>
        <field name="model">ktx.expense.dashboard</field>
        <field name="arch" type="xml">
            <form string="Tablero" create="false" edit="false" delete="false">
                <sheet>
                    <field name="company_currency_id" invisible="1"/>

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="mb-0" style="color:#2d3748;font-weight:700">
                            📊 Tablero de Liquidaciones
                        </h2>
                        <button name="action_open_dashboard" type="object"
                            string="↺ Actualizar" class="btn btn-sm btn-outline-secondary"/>
                    </div>

                    <!-- KPI Cards: Estados -->
                    <div class="row g-3 mb-3">
                        <div class="col-6 col-md-4 col-lg">
                            <div class="card h-100 border-0 shadow-sm" style="background:linear-gradient(135deg,#667eea,#764ba2)">
                                <div class="card-body text-white text-center p-3">
                                    <div style="font-size:2rem;font-weight:800;line-height:1"><field name="total_draft"/></div>
                                    <div style="font-size:0.8rem;opacity:0.9;margin-top:4px">📝 Borrador</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg">
                            <div class="card h-100 border-0 shadow-sm" style="background:linear-gradient(135deg,#f6d365,#fda085)">
                                <div class="card-body text-white text-center p-3">
                                    <div style="font-size:2rem;font-weight:800;line-height:1"><field name="total_confirmed"/></div>
                                    <div style="font-size:0.8rem;opacity:0.9;margin-top:4px">⏳ Por Autorizar</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg">
                            <div class="card h-100 border-0 shadow-sm" style="background:linear-gradient(135deg,#4facfe,#00f2fe)">
                                <div class="card-body text-white text-center p-3">
                                    <div style="font-size:2rem;font-weight:800;line-height:1"><field name="total_approved"/></div>
                                    <div style="font-size:0.8rem;opacity:0.9;margin-top:4px">✅ Aprobadas</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg">
                            <div class="card h-100 border-0 shadow-sm" style="background:linear-gradient(135deg,#43e97b,#38f9d7)">
                                <div class="card-body text-white text-center p-3">
                                    <div style="font-size:2rem;font-weight:800;line-height:1"><field name="total_posted"/></div>
                                    <div style="font-size:0.8rem;opacity:0.9;margin-top:4px">📤 Publicadas</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg">
                            <div class="card h-100 border-0 shadow-sm" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                                <div class="card-body text-white text-center p-3">
                                    <div style="font-size:2rem;font-weight:800;line-height:1"><field name="total_paid"/></div>
                                    <div style="font-size:0.8rem;opacity:0.9;margin-top:4px">💰 Pagadas</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- KPI Cards: Montos y Staging -->
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm" style="border-left:4px solid #f6c23e!important">
                                <div class="card-body p-3">
                                    <div class="text-muted" style="font-size:0.75rem;font-weight:600;text-transform:uppercase">Monto Pendiente</div>
                                    <div style="font-size:1.1rem;font-weight:700;color:#f6c23e;margin-top:4px">
                                        <field name="amount_pending" widget="monetary" options="{'currency_field':'company_currency_id'}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm" style="border-left:4px solid #1cc88a!important">
                                <div class="card-body p-3">
                                    <div class="text-muted" style="font-size:0.75rem;font-weight:600;text-transform:uppercase">Pagado Este Mes</div>
                                    <div style="font-size:1.1rem;font-weight:700;color:#1cc88a;margin-top:4px">
                                        <field name="amount_paid_month" widget="monetary" options="{'currency_field':'company_currency_id'}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm" style="border-left:4px solid #4e73df!important">
                                <div class="card-body p-3">
                                    <div class="text-muted" style="font-size:0.75rem;font-weight:600;text-transform:uppercase">Pagado Este Año</div>
                                    <div style="font-size:1.1rem;font-weight:700;color:#4e73df;margin-top:4px">
                                        <field name="amount_paid_year" widget="monetary" options="{'currency_field':'company_currency_id'}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm" style="border-left:4px solid #858796!important">
                                <div class="card-body p-3">
                                    <div class="text-muted" style="font-size:0.75rem;font-weight:600;text-transform:uppercase">Gastos Pendientes</div>
                                    <div style="font-size:1.1rem;font-weight:700;color:#858796;margin-top:4px">
                                        <field name="staging_pending"/> pendientes /
                                        <field name="staging_in_settlement"/> en liq.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Navigation Buttons -->
                    <div class="d-flex gap-2 flex-wrap mb-4">
                        <button name="%(ktx_expense_management.action_ktx_settlement)d"
                            type="action" string="📋 Ver Liquidaciones" class="btn btn-primary"/>
                        <button name="%(ktx_expense_management.action_ktx_settlement_staging)d"
                            type="action" string="📂 Gastos por Liquidar" class="btn btn-outline-primary"/>
                        <button name="%(ktx_expense_management.action_ktx_settlement_approvals)d"
                            type="action" string="✅ Autorizaciones" class="btn btn-outline-warning"/>
                    </div>

                    <!-- Charts Row -->
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-white border-0 pb-0">
                                    <h6 class="mb-0" style="color:#4e73df;font-weight:700">👤 Top Empleados por Gasto</h6>
                                    <small class="text-muted">Monto total en liquidaciones aprobadas/pagadas</small>
                                </div>
                                <div class="card-body pt-2">
                                    <field name="top_employees_html" widget="html" readonly="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-white border-0 pb-0">
                                    <h6 class="mb-0" style="color:#1cc88a;font-weight:700">🏪 Top Proveedores Liquidados</h6>
                                    <small class="text-muted">Monto total pagado por proveedor</small>
                                </div>
                                <div class="card-body pt-2">
                                    <field name="top_partners_html" widget="html" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Monthly Chart -->
                    <div class="card border-0 shadow-sm mb-2">
                        <div class="card-header bg-white border-0 pb-0">
                            <h6 class="mb-0" style="color:#36b9cc;font-weight:700">📈 Gasto Mensual — Últimos 12 Meses</h6>
                            <small class="text-muted">Liquidaciones publicadas y pagadas</small>
                        </div>
                        <div class="card-body">
                            <field name="monthly_html" widget="html" readonly="1"/>
                        </div>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ktx_expense_dashboard" model="ir.actions.server">
        <field name="name">Tablero Liquidaciones</field>
        <field name="model_id" ref="model_ktx_expense_dashboard"/>
        <field name="binding_model_id" ref="model_ktx_expense_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = env['ktx.expense.dashboard'].action_open_dashboard()</field>
    </record>

</odoo>
