<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ktx_settlement_reject_wizard_form" model="ir.ui.view">
        <field name="name">ktx.settlement.reject.wizard.form</field>
        <field name="model">ktx.settlement.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Rechazar Liquidación">
                <field name="settlement_id" invisible="1"/>
                <group>
                    <field name="rejection_note"
                        string="Motivo de Rechazo"
                        placeholder="Ingrese el motivo de rechazo..."
                        nolabel="1"/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                        string="Confirmar Rechazo"
                        type="object"
                        class="btn-danger"/>
                    <button string="Cancelar"
                        class="btn-secondary"
                        special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
